@page "/movies/edit"
@using Abc.Infra
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<AbcSoftMoviesContext> DbFactory
@inject NavigationManager NavigationManager
@using Abc.Data
<PageTitle>Edit</PageTitle>

<h1>Edit</h1>

<h2>Movie</h2>
<hr />
@if (Movie is null)
{
	<p><em>Loading...</em></p>
}
else
{
	<div class="row">
		<div class="col-md-4">
			<EditForm method="post" Model="Movie" OnValidSubmit="UpdateMovie" FormName="edit" Enhance>
				<DataAnnotationsValidator />
				<ValidationSummary role="alert" />
				<input type="hidden" name="Movie.Id" value="@Movie.Id" />
				<MyEntityEditor Entity="@Movie" />

				@* <MyPropertyEditor TValue="string" Id="title" Label="Title:" @bind-Value="Movie.Name" />
				<MyPropertyEditor TValue="DateTime?" Id="releasedate" Label="ReleaseDate:" @bind-Value="Movie.ValidFrom" />
				<MyPropertyEditor TValue="string" Id="genre" Label="Genre:" @bind-Value="Movie.Genre" />
				<MyPropertyEditor TValue="decimal" Id="price" Label="Price:" @bind-Value="Movie.Price" /> *@

				<button type="submit" class="btn btn-primary">Save</button>
			</EditForm>
		</div>
	</div>
}

<div>
    <a href="/movies">Back to List</a>
</div>

@code {
	[SupplyParameterFromQuery] private int Id { get; set; }
	[SupplyParameterFromForm] private Movie Movie { get; set; } = default!;

	protected override async Task OnInitializedAsync()
	{
		using var context = DbFactory.CreateDbContext();
		Movie ??= await context.Movies.FirstOrDefaultAsync(m => m.Id == Id);
		if (Movie is null)
		{
			NavigationManager.NavigateTo("/404", true);
			return;
		}
	}

	// To protect from overposting attacks, enable the specific properties you want to bind to.
	// For more information, see https://learn.microsoft.com/aspnet/core/blazor/forms/#mitigate-overposting-attacks.
	private async Task UpdateMovie()
	{
		using var context = DbFactory.CreateDbContext();

		Movie? dbMovie = await context.Movies.FirstOrDefaultAsync(m => m.Id == Movie.Id);

		if (dbMovie is null)
		{
			NavigationManager.NavigateTo("/404", true);
			return;
		}

		dbMovie.Name = Movie.Name;
		dbMovie.ValidFrom = Movie.ValidFrom;
		dbMovie.ValidTo = Movie.ValidTo;
		dbMovie.Genre = Movie.Genre;
		dbMovie.Price = Movie.Price;

		await context.SaveChangesAsync();
		NavigationManager.NavigateTo("/movies");
	}

	private bool MovieExists(int id)
	{
		using var context = DbFactory.CreateDbContext();
		return context.Movies.Any(e => e.Id == id);
	}
}